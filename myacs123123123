			end)
		end
	end

	local BulletMass = Bullet:GetMass()
	local Force = Vector3.new(0, BulletMass * (196.2) - (WeaponData.BulletDrop) * (196.2), 0)
	local BF = Instance.new("BodyForce", Bullet)
