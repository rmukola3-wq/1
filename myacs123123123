local function motionScale()
	local s = 1.0
	if BipodActive then
		s = s * VM_Config.bipodScale
	elseif Crouched or Proned then
		s = s * VM_Config.crouchScale
	elseif runKeyDown then
		s = s * VM_Config.sprintScale
	end
	if aimming then
		s = s * VM_Config.adsMotionScale
	end
	return s
end

Run.RenderStepped:Connect(function(step)
	HeadMovement()

	renderGunRecoil()
	renderCam()

	LeanVisualZ = LeanVisualZ + (((-14 * Virar) - LeanVisualZ) * math.clamp(step * 7, 0, 1))
	cam.CFrame = cam.CFrame * CFrame.Angles(0, 0, math.rad(LeanVisualZ))


	if ViewModel and LArm and RArm and WeaponInHand then

		local now = tick()
		local ms = motionScale()
		local mouseDelta = User:GetMouseDelta()
		recoilAimBlend = recoilAimBlend + (((aimming and 1 or 0) - recoilAimBlend) * math.clamp(step * 10, 0, 1))
		local justEnteredADS = aimming and not wasAiming
		local justLeftADS = (not aimming) and wasAiming

		if justEnteredADS then
			adsEntryVariant = math.random(1, 3)

			if adsEntryVariant == 1 then
				adsEntryPosSpring:accelerate(Vector3.new(-0.030, -0.020, 0.050))
				adsEntryRotSpring:accelerate(Vector3.new(math.rad(-1.8), math.rad(0.9), math.rad(-2.2)))
			elseif adsEntryVariant == 2 then
				adsEntryPosSpring:accelerate(Vector3.new(0.030, -0.020, 0.050))
				adsEntryRotSpring:accelerate(Vector3.new(math.rad(-1.8), math.rad(-0.9), math.rad(2.2)))
			else
				adsEntryPosSpring:accelerate(Vector3.new(0.000, -0.016, 0.040))
				adsEntryRotSpring:accelerate(Vector3.new(math.rad(-1.2), 0, 0))
			end
		end

		if justLeftADS then
			adsEntryPosSpring:accelerate(Vector3.new(0.000, 0.010, -0.020))
			adsEntryRotSpring:accelerate(Vector3.new(math.rad(0.6), 0, 0))
		end

		wasAiming = aimming

		local adsEntryPos = adsEntryPosSpring.p
		local adsEntryRot = adsEntryRotSpring.p

		adsEntryCF =
			CFrame.new(adsEntryPos.X, adsEntryPos.Y, adsEntryPos.Z)
			* CFrame.Angles(adsEntryRot.X, adsEntryRot.Y, adsEntryRot.Z)
		if aimming and AnimDebounce and not CheckingMag then
			adsStage = math.min(1, adsStage + (step / ADS_IN_TIME))
		else
			adsStage = math.max(0, adsStage - (step / ADS_OUT_TIME))
		end

		local shoulderFade = 1 - ease01(math.clamp((adsStage - 0.05) / 0.50, 0, 1))

		adsShoulderCF =
			CFrame.new(
				0.085 * shoulderFade,
				-0.045 * shoulderFade,
				-0.12 * shoulderFade
			)
			* CFrame.Angles(
				math.rad(-2.2 * shoulderFade),
				math.rad(0.8 * shoulderFade),
				math.rad(2.5 * shoulderFade)
			)

		local adsFineAlpha = ease01(math.clamp((adsStage - ADS_FINE_START) / (1 - ADS_FINE_START), 0, 1))
		do
			local target = Virar
			local speed = (math.abs(target) > math.abs(leanWeaponBlend)) and leanWeaponInSpeed or leanWeaponOutSpeed

			leanWeaponBlend = leanWeaponBlend + (target - leanWeaponBlend) * math.clamp(step * speed, 0, 1)

			local blendAbs = math.abs(leanWeaponBlend)

			leanWeaponCF =
				CFrame.new(
					0.085 * leanWeaponBlend,
					-0.012 * blendAbs,
					-0.035 * blendAbs
				)
				* CFrame.Angles(
					math.rad(-1.0 * blendAbs),
					math.rad(4.0 * leanWeaponBlend),
					math.rad(7.0 * leanWeaponBlend)
				)
		end

		-- Crouch stance layer
		do
			local crouchTarget = 0
			if Crouched == true or Stances == 1 or stance == 1 then
				crouchTarget = 1
			end
			if Bipod == true then
				crouchTarget = 0
			end
			crouchBlend = crouchBlend + (crouchTarget - crouchBlend) * math.clamp(step * VM_Config.crouchBlendSpeed, 0, 1)
			local crouchMul = lerpNum(1, VM_Config.crouchAdsMultiplier, adsBlend)
			crouchCF =
				CFrame.new(
					0,
					-VM_Config.crouchDropY * crouchBlend * crouchMul,
					VM_Config.crouchPushZ * crouchBlend * crouchMul
				)
				* CFrame.Angles(
					math.rad(VM_Config.crouchPitch * crouchBlend * crouchMul),
					math.rad(VM_Config.crouchYaw   * crouchBlend * crouchMul),
					math.rad(VM_Config.crouchRoll  * crouchBlend * crouchMul)
				)
		end

		-- Strafe tilt layer
		do
			local relVel = HumanoidRootPart.CFrame:VectorToObjectSpace(HumanoidRootPart.Velocity)
			local moveDirLocal = HumanoidRootPart.CFrame:VectorToObjectSpace(Humanoid.MoveDirection)
			local sideVel = relVel.X
			local sideIntent = moveDirLocal.X
			local walkRef = math.max(char.Humanoid.WalkSpeed, 1)
			local sideNorm = math.clamp(sideVel / walkRef, -1, 1)
			if math.abs(sideNorm) < 0.08 then
				sideNorm = sideNorm + sideIntent * VM_Config.strafeInputAssist
			end
			sideNorm = math.clamp(sideNorm, -1, 1)
			if math.abs(sideNorm) < VM_Config.strafeTiltDeadzone then
				sideNorm = 0
			end
			local tiltScale = 1
			if aimming then tiltScale = tiltScale * VM_Config.strafeTiltADSScale end
			if Crouched then tiltScale = tiltScale * VM_Config.strafeTiltCrouchScale end
			if Proned then tiltScale = tiltScale * VM_Config.strafeTiltProneScale end
			if runKeyDown then tiltScale = tiltScale * VM_Config.strafeTiltSprintScale end
			if BipodActive then tiltScale = 0 end
			local targetRoll = math.rad(-VM_Config.strafeTiltMaxRoll * sideNorm * tiltScale)
			local targetYaw  = math.rad(VM_Config.strafeTiltMaxYaw  * sideNorm * tiltScale)
			strafeTilt    = strafeTilt    + (targetRoll - strafeTilt)    * math.clamp(step * VM_Config.strafeTiltResponse, 0, 1)
			strafeTiltYaw = strafeTiltYaw + (targetYaw  - strafeTiltYaw) * math.clamp(step * VM_Config.strafeTiltResponse, 0, 1)
			strafeTiltCF = CFrame.Angles(0, strafeTiltYaw, strafeTilt)
		end

		-- Turn roll layer
		do
			local turnScale = 1
			if aimming then turnScale = turnScale * VM_Config.turnRollADSScale end
			if Crouched then turnScale = turnScale * VM_Config.turnRollCrouchScale end
			if Proned then turnScale = turnScale * VM_Config.turnRollProneScale end
			if runKeyDown then turnScale = turnScale * VM_Config.turnRollSprintScale end
			if BipodActive then turnScale = 0 end

			local targetTurnRoll = math.clamp(
				-mouseDelta.X / VM_Config.turnRollInputDiv,
				-VM_Config.turnRollMax,
				VM_Config.turnRollMax
			) * turnScale

			turnRoll = turnRoll + (targetTurnRoll - turnRoll) * math.clamp(step * VM_Config.turnRollResponse, 0, 1)
			turnRollCF = CFrame.Angles(0, 0, math.rad(turnRoll))
		end

		-- Sway
		local swayScale = aimming and adsSwayScale or 1
		SwaySpring:accelerate(Vector3.new((mouseDelta.x / 60) * swayScale, (mouseDelta.y / 60) * swayScale, 0))

		local fatigueScale = 1
		if donorAimFatigueState then
			fatigueScale = donorAimFatigueState:Update(
				step,
				aimming,
				Steady,
				charspeed > 0.1
			)
		end

		local donorBaseCF = CFrame.new()
		if donorMotionSwayState then
			local donorLookCF, donorWalkCF = donorMotionSwayState:Update(
				step,
				mouseDelta,
				charspeed,
				aimming,
				runKeyDown,
				(Crouched or Proned),
				fatigueScale
			)
			donorBaseCF = donorLookCF * donorWalkCF
		end

		adsBlend = adsBlend + ((aimming and 1 or 0) - adsBlend) * math.clamp(
			step * (aimming and ADS_BLEND_IN_SPEED or ADS_BLEND_OUT_SPEED),
			0,
			1
		)

		do
			local adjust = step * 60
			local md = mouseDelta
			local mdMag = md.Magnitude

			local sens      = lerpNum(VM_Config.offsetSensHip,      VM_Config.offsetSensADS,      adsBlend)
			local returnMin = lerpNum(VM_Config.offsetReturnMinHip, VM_Config.offsetReturnMinADS, adsBlend)
			local returnMul = lerpNum(VM_Config.offsetReturnMulHip, VM_Config.offsetReturnMulADS, adsBlend)
			local angleMax  = lerpNum(VM_Config.offsetAngleHip,     VM_Config.offsetAngleADS,     adsBlend)

			local rotK   = lerpNum(LAG_ROT_HIP, LAG_ROT_ADS, adsBlend)
			local posK   = lerpNum(LAG_POS_HIP, LAG_POS_ADS, adsBlend)
			local lagMax = lerpNum(LAG_MAX_HIP, LAG_MAX_ADS, adsBlend)

			aimOffsetThing = aimOffsetThing - (md * sens)

			if adsBlend > 0.001 or mdMag < VM_Config.offsetDeadzone then
				aimOffsetThing = aimOffsetThing + Vector2.new(
					recaimoff(aimOffsetThing.X, returnMin, returnMul, adjust),
					recaimoff(aimOffsetThing.Y, returnMin, returnMul, adjust)
				)
			end

			local clampAlpha = math.clamp(step * lerpNum(12, 14, adsBlend), 0, 1)
			if aimOffsetThing.Magnitude > angleMax then
				aimOffsetThing = aimOffsetThing:Lerp(aimOffsetThing.Unit * angleMax, clampAlpha)
			end

			local velTarget = Vector2.new(
				math.clamp(-md.X * VM_Config.adsVelocityBuild, -VM_Config.adsCarryClamp, VM_Config.adsCarryClamp),
				math.clamp(-md.Y * VM_Config.adsVelocityBuild, -VM_Config.adsCarryClamp, VM_Config.adsCarryClamp)
			) * adsBlend

			adsLagVelocity = adsLagVelocity:Lerp(
				velTarget,
				math.clamp(step * VM_Config.adsVelocityDamp, 0, 1)
			)

			LagSpring.t = Vector3.new(
				math.clamp(-md.Y * rotK, -lagMax, lagMax),
				math.clamp(-md.X * rotK, -lagMax, lagMax),
				0
			)

			local lp = LagSpring.p
			local lagPosLimitX = lerpNum(0.045, VM_Config.adsLagPosClampX, adsBlend)
			local lagPosLimitY = lerpNum(0.035, VM_Config.adsLagPosClampY, adsBlend)

			local lagPosX = math.clamp(-md.X * posK, -lagPosLimitX, lagPosLimitX)
			local lagPosY = math.clamp(-md.Y * posK, -lagPosLimitY, lagPosLimitY)

			local aimOffsetCF = CFrame.new(
				aimOffsetThing.X * VM_Config.offsetPosMul,
				aimOffsetThing.Y * -VM_Config.offsetPosMul,
				0
			) * CFrame.Angles(
				math.rad(aimOffsetThing.Y * VM_Config.offsetRotMul),
				math.rad(aimOffsetThing.X * VM_Config.offsetRotMul),
				0
			)

			local lagCF = CFrame.new(lagPosX, lagPosY, 0) * CFrame.Angles(lp.X, lp.Y, 0)

			adsCarryCF = CFrame.new(
				adsLagVelocity.X * VM_Config.adsCarryPosMul,
				adsLagVelocity.Y * -VM_Config.adsCarryPosMul,
				0
			) * CFrame.Angles(
				math.rad(adsLagVelocity.Y * VM_Config.adsCarryRotMul),
				math.rad(adsLagVelocity.X * VM_Config.adsCarryRotMul),
				0
			)

			lookSwayCF = donorBaseCF * aimOffsetCF * lagCF * adsCarryCF
		end

		if donorBreathState then
			breathCF = donorBreathState:Update(
				step,
				aimming,
				charspeed > 0.1,
				fatigueScale
			)
		else
			breathCF = CFrame.new()
		end

		-- Long-aim drift
		do
			if aimming then
				local elapsed   = now - adsStartTime
				local driftFade = math.clamp((elapsed - VM_Config.driftStartSec) / 1.5, 0, 1)
				local dx = math.sin(now * VM_Config.driftFreq * math.pi * 2 + driftPhaseX) * VM_Config.driftAmp * driftFade
				local dy = math.cos(now * VM_Config.driftFreq * math.pi * 2 * 0.7 + driftPhaseY) * VM_Config.driftAmp * driftFade
				driftCF = CFrame.Angles(dy, dx, 0)
			else
				driftCF = driftCF:Lerp(CFrame.new(), alphaFromSpeed(8, step))
			end
		end

		-- Secondary bobble
		do
			local sp = SecondarySpring.p
			secondaryCF = CFrame.new(
				sp.X * VM_Config.secondaryAmp * 40 * ms,
				sp.Y * VM_Config.secondaryAmp * 40 * ms,
				0
			) * CFrame.Angles(sp.X * 0.5 * ms, sp.Y * 0.5 * ms, 0)

			if not shooting and charspeed < 0.1 then
				SecondarySpring.t = Vector3.new(
					math.sin(now * VM_Config.secondaryFreq * math.pi * 2) * VM_Config.secondaryAmp * ms,
					math.cos(now * VM_Config.secondaryFreq * math.pi * 2 * 0.6) * VM_Config.secondaryAmp * ms,
					0
				)
			else
				SecondarySpring.t = Vector3.new(0, 0, 0)
			end
		end

		-- Sway legacy
		local swayVec = SwaySpring.p
		local Sway = CFrame.Angles(swayVec.Y, swayVec.X, swayVec.X)

		if BipodAtt then
			local BipodRay = Ray.new(UnderBarrelAtt.Main.Position, Vector3.new(0, -1.75, 0))
			local BipodHit, BipodPos, BipodNorm = workspace:FindPartOnRayWithIgnoreList(BipodRay, Ignore_Model, false, true)
			if BipodHit then
				CanBipod = true
				if CanBipod and BipodActive and not runKeyDown and (GunStance == 0 or GunStance == 2) then
					TS:Create(SE_GUI.GunHUD.Att.Bipod, TweenInfo.new(.1, Enum.EasingStyle.Linear), {ImageColor3 = Color3.fromRGB(255, 255, 255), ImageTransparency = .123}):Play()
					if not aimming then
						BipodCF = lerpCF_dt(BipodCF, CFrame.new(0, (((UnderBarrelAtt.Main.Position - BipodPos).magnitude) - 1) * (-1.5), 0), 14, step)
					else
						BipodCF = BipodCF:Lerp(CFrame.new(), .2)
					end
				else
					BipodActive = false
					BipodCF = BipodCF:Lerp(CFrame.new(), .2)
					TS:Create(SE_GUI.GunHUD.Att.Bipod, TweenInfo.new(.1, Enum.EasingStyle.Linear), {ImageColor3 = Color3.fromRGB(255, 255, 0), ImageTransparency = .5}):Play()
				end
			else
				BipodActive = false
				CanBipod = false
				BipodCF = BipodCF:Lerp(CFrame.new(), .2)
				TS:Create(SE_GUI.GunHUD.Att.Bipod, TweenInfo.new(.1, Enum.EasingStyle.Linear), {ImageColor3 = Color3.fromRGB(255, 0, 0), ImageTransparency = .5}):Play()
			end
		end

		-- VMKick assembly
		local kp = VMKickPos.p
		local kr = VMKickRot.p
		vmKickCF = CFrame.new(kp) * CFrame.Angles(kr.X, kr.Y, kr.Z)

		-- VM_Bump wall collision
		do
			local bumpTarget = CFrame.new()
			local pushTarget = CFrame.new()
			VM_Bump = false

			local PUSH_START_DIST = 2.5
			local PUSH_MAX        = 1.5
			local PUSH_SPEED      = 22

			if ToolEquip and WeaponInHand and WeaponData and WeaponData.Type == "Gun" and AnimDebounce then
				local origin  = (cam.CFrame * CFrame.new(0, 0, -1.3)).Position
				local look    = cam.CFrame.LookVector
				local castDist = BUMP_EXIT_DIST + 0.75
				local dir     = look * castDist

				local params = RaycastParams.new()
				params.FilterType = Enum.RaycastFilterType.Exclude
				params.FilterDescendantsInstances = {char, cam, ViewModel, WeaponInHand, ACS_Workspace.Client, ACS_Workspace.Server}
				params.IgnoreWater = true

				local hit    = workspace:Raycast(origin, dir, params)
				local hitOk  = false
				local dist   = math.huge

				if hit and hit.Instance and hit.Instance:IsA("BasePart") then
					local p = hit.Instance
					if p.Transparency < 1 and p.Name ~= "HitIgnore" then
						hitOk = true
						dist  = (hit.Position - origin).Magnitude
					end
				end

				local wantBump = false
				if hitOk then
					local thresh = VM_BumpPrev and BUMP_EXIT_DIST or BUMP_ENTER_DIST
					if dist <= thresh then
						wantBump = true
					end
				end

				if wantBump then
					bumpHitFrames  = math.min(bumpHitFrames + 1, BUMP_HIT_FRAMES)
					bumpLostFrames = 0
				else
					bumpLostFrames = bumpLostFrames + 1
					bumpHitFrames  = 0
				end

				if VM_BumpPrev then
					VM_Bump = (bumpLostFrames < BUMP_LOST_FRAMES)
				else
					VM_Bump = (bumpHitFrames >= BUMP_HIT_FRAMES)
				end

				if VM_Bump then
					bumpTarget = BUMP_POSE
					if hitOk then
						if dist < PUSH_START_DIST then
							local t    = math.clamp((PUSH_START_DIST - dist) / PUSH_START_DIST, 0, 1)
							local push = t * PUSH_MAX
							pushTarget = CFrame.new(0, 0, push)
						end
					end
				end
			end

			bumpCF     = lerpCF_dt(bumpCF,     bumpTarget, BUMP_SPEED, step)
			bumpPushCF = lerpCF_dt(bumpPushCF, pushTarget, PUSH_SPEED, step)

			if VM_Bump then
				if aimming then
					if not BumpAdsCut then
						BumpAdsCut = true
						aimming = false
						ADS(false)
					else
						aimming = false
					end
				end
			else
				BumpAdsCut = false
			end
			CanFire     = not VM_Bump
			VM_BumpPrev = VM_Bump
		end

		-- Recoil update
		local dt = step
		local newRecoilCF = gunRecoilState:Update(dt)
		recoilcf = newRecoilCF

		donorRecoilCF = donorRecoilState:Update(dt)
		cameraKickCF  = recoilCameraState:Update(dt)
		shotBobbleCF  = shotBobbleState:Update(dt, charspeed > 0.1, aimming)

		-- ШАГ 6 (НОВОЕ): обновляем DonorFireKick каждый кадр
		donorFireKickCF = donorFireKickState:Update(dt, aimming and 1 or 0)

		local isMoving = charspeed > 0.1
		local isSprinting = runKeyDown == true

		walkAlpha = walkAlpha + ((isMoving and 1 or 0) - walkAlpha) * math.clamp(step * 8, 0, 1)

		if isMoving then
			walkTime += step * (isSprinting and 8 or 7)
		end

		local moveMul = isSprinting and 3.0 or 1

		local walkX = math.sin(walkTime) * 0.05 * moveMul * walkAlpha
		local walkY = math.cos(walkTime * 2) * 0.025 * moveMul * walkAlpha
		local walkRoll = math.rad(math.sin(walkTime) * (isSprinting and 2.0 or 1.2)) * walkAlpha

		local targetBob =
			CFrame.new(walkX, walkY, 0) *
			CFrame.Angles(0, 0, walkRoll)

		gunbobcf = gunbobcf:Lerp(targetBob, math.clamp(step * 10, 0, 1))

		-- ШАГ 7 (НОВОЕ): AnimPart.CFrame — donorFireKickCF вместо shotKickCF
		AnimPart.CFrame = cam.CFrame
			* NearZ
			* BipodCF
			* maincf
			* adsShoulderCF
			* crouchCF
			* strafeTiltCF
			* turnRollCF
			* leanWeaponCF
			* lookSwayCF
			* gunbobcf
			* breathCF
			* driftCF
			* aimcf
			* donorRecoilCF
			* recoilcf
			* donorFireKickCF   -- НОВОЕ: заменяет shotKickCF
			* vmKickCF
			* shotBobbleCF
			* secondaryCF
			* bumpPushCF
			* bumpCF

		if not AnimData.GunModelFixed then
			WeaponInHand:SetPrimaryPartCFrame(
				ViewModel.PrimaryPart.CFrame * guncf
			)
		end

		-- Walk bob
		-- handled above

		-- ADS viewmodel positioning
		if CurAimpart and aimming and AnimDebounce and not CheckingMag then
			if not NVG or WeaponInHand.AimPart:FindFirstChild("NVAim") == nil then
				if AimPartMode == 1 then
					TS:Create(cam, TweenInfo.new(0.35, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut), {FieldOfView = ModTable.ZoomValue}):Play()
					maincf = lerpCF_dt(maincf, maincf * CFrame.new(0, 0, -.5) * Sway:inverse() * CurAimpart.CFrame:toObjectSpace(cam.CFrame), 8, step)
				else
					TS:Create(cam, TweenInfo.new(0.35, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut), {FieldOfView = ModTable.Zoom2Value}):Play()
					maincf = lerpCF_dt(maincf, maincf * CFrame.new(0, 0, -.5) * Sway:inverse() * CurAimpart.CFrame:toObjectSpace(cam.CFrame), 8, step)
				end
			else
				TS:Create(cam, TweenInfo.new(0.35, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut), {FieldOfView = 70}):Play()
				maincf = maincf:Lerp(maincf * CFrame.new(0, 0, -.5) * Sway:inverse() * (WeaponInHand.AimPart.CFrame * WeaponInHand.AimPart.NVAim.CFrame):toObjectSpace(cam.CFrame), 0.08)
			end
		else
			TS:Create(cam, TweenInfo.new(0.35, Enum.EasingStyle.Linear, Enum.EasingDirection.InOut), {FieldOfView = 70}):Play()
			maincf = lerpCF_dt(maincf, AnimData.MainCFrame * Sway:inverse(), 8, step)
		end
		-- ADS micro motion
		if aimming and AnimDebounce and not CheckingMag then
			local adsPosX = math.clamp(-mouseDelta.X * 0.000030, -0.0010, 0.0010)
			local adsPosY = math.clamp(-mouseDelta.Y * 0.000030, -0.0010, 0.0010)

			local adsPitch = math.clamp(-mouseDelta.Y * 0.000075, -0.0014, 0.0014)
			local adsYaw   = math.clamp(-mouseDelta.X * 0.000075, -0.0014, 0.0014)
			local adsRoll  = math.clamp(mouseDelta.X  * 0.000020, -0.0006, 0.0006)

			local breathMul = (charspeed > 0.1) and 0.35 or 1.0
			local breathPitch = math.rad(0.018 * breathMul) * math.sin(now * 2.0)
			local breathYaw   = math.rad(0.018 * breathMul) * math.cos(now * 1.6)

			ADSAimSpring.t = Vector3.new(
				adsPitch + breathPitch,
				adsYaw + breathYaw,
				adsRoll
			)

			local adsAimVec = ADSAimSpring.p

			aimcf =
				CFrame.new(adsPosX, adsPosY, 0)
				* CFrame.Angles(
					adsAimVec.X,
					adsAimVec.Y,
					adsAimVec.Z
				)
		else
			ADSAimSpring.t = Vector3.new()
			aimcf = CFrame.new()
		end

		-- Crosshair
		if WeaponData.CrossHair then
			if aimming then
				CHup    = lerpUDim2_dt(CHup,    UDim2.new(.5, 0, .5, 0), 14, step)
				CHdown  = lerpUDim2_dt(CHdown,  UDim2.new(.5, 0, .5, 0), 14, step)
				CHleft  = lerpUDim2_dt(CHleft,  UDim2.new(.5, 0, .5, 0), 14, step)
				CHright = lerpUDim2_dt(CHright, UDim2.new(.5, 0, .5, 0), 14, step)
			else
				local Normalized = ((WeaponData.CrosshairOffset + BSpread + (charspeed * WeaponData.WalkMult * ModTable.WalkMult)) / 50) / 10
				CHup    = lerpUDim2_dt(CHup,    UDim2.new(0.5, 0, 0.5 - Normalized, 0), 35, step)
				CHdown  = lerpUDim2_dt(CHdown,  UDim2.new(.5, 0, 0.5 + Normalized, 0), 35, step)
				CHleft  = lerpUDim2_dt(CHleft,  UDim2.new(.5 - Normalized, 0, 0.5, 0), 35, step)
				CHright = lerpUDim2_dt(CHright, UDim2.new(.5 + Normalized, 0, 0.5, 0), 35, step)
			end
			Crosshair.Position    = UDim2.new(0, mouse.X, 0, mouse.Y)
			Crosshair.Up.Position    = CHup
			Crosshair.Down.Position  = CHdown
			Crosshair.Left.Position  = CHleft
			Crosshair.Right.Position = CHright
		else
			CHup    = lerpUDim2_dt(CHup,    UDim2.new(.5, 0, .5, 0), 14, step)
			CHdown  = lerpUDim2_dt(CHdown,  UDim2.new(.5, 0, .5, 0), 14, step)
			CHleft  = lerpUDim2_dt(CHleft,  UDim2.new(.5, 0, .5, 0), 14, step)
			CHright = lerpUDim2_dt(CHright, UDim2.new(.5, 0, .5, 0), 14, step)
			Crosshair.Position    = UDim2.new(0, mouse.X, 0, mouse.Y)
			Crosshair.Up.Position    = CHup
			Crosshair.Down.Position  = CHdown
			Crosshair.Left.Position  = CHleft
			Crosshair.Right.Position = CHright
		end

		-- Spread decay
		if BSpread then
			local currTime = time()
			if currTime - LastSpreadUpdate > (60 / WeaponData.ShootRate) * 2 and not shooting and BSpread > WeaponData.MinSpread * ModTable.MinSpread then
				BSpread = math.max(WeaponData.MinSpread * ModTable.MinSpread, BSpread - WeaponData.AimInaccuracyDecrease * ModTable.AimInaccuracyDecrease)
			end
			if currTime - LastSpreadUpdate > (60 / WeaponData.ShootRate) * 1.5 and not shooting and RecoilPower > WeaponData.MinRecoilPower * ModTable.MinRecoilPower then
				RecoilPower = math.max(WeaponData.MinRecoilPower * ModTable.MinRecoilPower, RecoilPower - WeaponData.RecoilPowerStepAmount * ModTable.RecoilPowerStepAmount)
			end
		end

		-- Laser pointer
		if LaserActive and Pointer ~= nil then
			if NVG then
				Pointer.Transparency = 0
				Pointer.Beam.Enabled = true
			else
				if not gameRules.RealisticLaser then
					Pointer.Beam.Enabled = true
				else
					Pointer.Beam.Enabled = false
				end
				if IRmode then
					Pointer.Transparency = 1
				else
					Pointer.Transparency = 0
				end
			end
			for index, Key in pairs(WeaponInHand:GetDescendants()) do
				if Key:IsA("BasePart") and Key.Name == "LaserPoint" then
					local L_361_ = Ray.new(Key.CFrame.Position, Key.CFrame.LookVector * 1000)
					local Hit, Pos, Normal = workspace:FindPartOnRayWithIgnoreList(L_361_, Ignore_Model, false, true)
					if Hit then
						Pointer.CFrame = CFrame.new(Pos, Pos + Normal)
					else
						Pointer.CFrame = CFrame.new(cam.CFrame.Position + Key.CFrame.LookVector * 2000, Key.CFrame.LookVector)
					end
					if HalfStep and gameRules.ReplicatedLaser then
						Evt.SVLaser:FireServer(Pos, 1, Pointer.Color, IRmode, WeaponTool)
					end
					break
				end
			end
		end
	end
end)

Evt.Refil.OnClientEvent:Connect(function(Tool, Infinite, Stored)
	local data = require(Tool.ACS_Settings)
	local NewStored = math.min(data.MaxStoredAmmo - StoredAmmo, Stored.Value)
	StoredAmmo = StoredAmmo + NewStored
	data.StoredAmmo = StoredAmmo
	UpdateGui()
	if not Infinite then
		Evt.Refil:FireServer(Stored, NewStored)
	end
end)
