local function recaimoff(value, minStep, multStep, adjust)
	if math.abs(value) < 0.0001 then
		return -value
	end

	local sign = value > 0 and -1 or 1
	local amount = math.max(minStep, math.abs(value) * multStep) * adjust
	if amount > math.abs(value) then
		amount = math.abs(value)
	end

	return sign * amount
end

