	elseif WeaponData.ShootType == 3 and WeaponData.FireModes.Semi == false and WeaponData.FireModes.Burst == true then
		WeaponData.ShootType = 2
	end
	UpdateGui()
end

local function RemoveClientHolster(weaponName)
	local existing = char:FindFirstChild("C_" .. weaponName)
	if existing then
		existing:Destroy()
	end
end

local function RemoveOwnServerHolster(weaponName)
	local existing = char:FindFirstChild("S_" .. weaponName)
	if existing then
		existing:Destroy()
	end
end

local function CreateClientHolster(toolName, settings)
	if not settings or not settings.Holster then return end

	local holsterPart = char:FindFirstChild(settings.HolsterPoint or "UpperTorso")
	if not holsterPart then
		warn("CLIENT HOLSTER MISSING BODY PART", settings.HolsterPoint, toolName)
		return
	end

	local modelName = settings.ClientHolsterModel or toolName
	local template = GunHolsterClient:FindFirstChild(modelName)
	if not template then
		warn("CLIENT HOLSTER MISSING MODEL", modelName, toolName)
		return
	end

	RemoveClientHolster(toolName)
	
	
	RemoveOwnServerHolster(toolName)

	local holsterModel = template:Clone()
	holsterModel.Name = "C_" .. toolName
	holsterModel.Parent = char

	for _, part in pairs(holsterModel:GetChildren()) do
		if part:IsA("BasePart") and part.Name ~= "Handle" then
			if part.Name == "SightMark" then
				part:Destroy()
			else
				local newWeld = Ultil.WeldComplex(holsterModel.Handle, part, part.Name)
				newWeld.Parent = holsterModel.Handle
				part.Anchored = false
				part.CanCollide = false
			end
		end
	end

	local holsterWeld = Ultil.Weld(holsterPart, holsterModel.Handle, settings.HolsterCFrame or CFrame.new())
	holsterWeld.Parent = holsterModel
	holsterWeld.Name = "HolsterWeld"
	holsterModel.Handle.Anchored = false
end

