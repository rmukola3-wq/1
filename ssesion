function DonorLikeRecoilModule:Update(dt)
dt = min(dt, 0.033)

local profile = self.currentProfile or {}

-- Apply return speed/smoothness if profile has them (donor: returnSpeed, returnSmoothness)
local returnSpeed = profile.returnSpeed or 0.17
local returnSmoothness = profile.returnSmoothness or 0.8

-- Update springs with profile-based stiffness
local springStiffness = profile.springStiffness or 75
local springDamping = profile.springDamping or 16

self.pitchSpring.stiffness = springStiffness
self.pitchSpring.damping = springDamping
self.yawSpring.stiffness = springStiffness * 0.85
self.yawSpring.damping = springDamping * 0.9
self.rollSpring.stiffness = springStiffness * 0.7
self.rollSpring.damping = springDamping * 0.8

local pitch = updateSpring(self.pitchSpring, dt)
local yaw = updateSpring(self.yawSpring, dt)
local roll = updateSpring(self.rollSpring, dt)

-- Clamp pitch to prevent excessive upward climb
local minPitch = profile.minPitch or -0.25
local maxPitch = profile.maxPitch or 0.65
local maxYaw = profile.maxYaw or 0.45
local maxRoll = profile.maxRoll or 0.3

pitch = clamp(pitch, minPitch, maxPitch)
yaw = clamp(yaw, -maxYaw, maxYaw)
roll = clamp(roll, -maxRoll, maxRoll)

-- Positional springs
local posX = updateSpring(self.posXSpring, dt)
local posY = updateSpring(self.posYSpring, dt)
local posZ = updateSpring(self.posZSpring, dt)

-- Decay spray over time
self.sprayAmount = max(0, self.sprayAmount - dt * 4.5)

-- Camera shake (donor: cameraShake)
local cameraShake = profile.cameraShake or 0.028
local shakeIntensity = (abs(self.pitchSpring.velocity) + abs(self.yawSpring.velocity)) * cameraShake * 0.015
local time = clock()

-- Build final CFrame
local posCF = CFrame.new(
	posX * 0.25 + sin(time * 47) * shakeIntensity,
	posY * 0.35 + cos(time * 38) * shakeIntensity,
	posZ * 0.4
)
local rotCF = CFrame.Angles(pitch, yaw, roll)

return posCF * rotCF


end

