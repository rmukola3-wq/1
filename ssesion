local ShotBobble = {}
ShotBobble.__index = ShotBobble

-- Shot bobble: light shake/bobble reaction after each shot
-- Separate from main recoil, adds life to viewmodel
-- Inspired by donor's secondary spring reactions

local random = math.random
local sin = math.sin
local cos = math.cos
local pi = math.pi

function ShotBobble.new()
local self = setmetatable({}, ShotBobble)

-- Bobble state
self.intensity = 0
self.phase = random() * pi * 2

-- Decay parameters
self.decayRate = 4.5  -- How fast bobble fades
self.frequency = 28   -- Bobble oscillation speed

-- Current bobble values
self.currentPos = Vector3.new(0, 0, 0)
self.currentRot = Vector3.new(0, 0, 0)

return self


end

function ShotBobble:Trigger(amount)
-- Add bobble impulse, accumulates for rapid fire
self.intensity = self.intensity + (amount or 1)
self.phase = random() * pi * 2  -- Randomize phase for variety
end

function ShotBobble:Update(dt, isMoving, isAiming)
dt = math.min(dt, 0.033)

-- Decay intensity over time
self.intensity = self.intensity * (1 - self.decayRate * dt)
if self.intensity < 0.001 then
	self.intensity = 0
end

-- Phase advances for oscillation
self.phase = self.phase + self.frequency * dt

-- Calculate bobble based on intensity
local bobbleAmount = self.intensity

-- Reduce when aiming (donor-like behavior)
if isAiming then
	bobbleAmount = bobbleAmount * 0.35
end

-- Slightly increase when moving
if isMoving then
	bobbleAmount = bobbleAmount * 1.15
end

-- Multi-frequency bobble for organic feel (donor uses multiple sine waves)
local bobbleX = sin(self.phase * 1.0) * 0.006 + cos(self.phase * 1.7) * 0.004
local bobbleY = sin(self.phase * 0.8 + 0.5) * 0.008 + cos(self.phase * 1.3) * 0.005
local bobbleZ = sin(self.phase * 1.2 + 1.0) * 0.003

-- Apply intensity
self.currentPos = Vector3.new(
	bobbleX * bobbleAmount,
	bobbleY * bobbleAmount,
	bobbleZ * bobbleAmount
)

-- Rotational bobble (lighter than positional)
local rotBobble = bobbleAmount * 0.7
self.currentRot = Vector3.new(
	sin(self.phase * 0.9) * 0.004 * rotBobble,  -- pitch
	sin(self.phase * 1.1 + 0.3) * 0.003 * rotBobble,  -- yaw
	sin(self.phase * 0.7 + 0.7) * 0.002 * rotBobble   -- roll
)

-- Build CFrame
local posCF = CFrame.new(self.currentPos.X, self.currentPos.Y, self.currentPos.Z)
local rotCF = CFrame.Angles(self.currentRot.X, self.currentRot.Y, self.currentRot.Z)

return posCF * rotCF


end

function ShotBobble:Reset()
self.intensity = 0
self.currentPos = Vector3.new(0, 0, 0)
self.currentRot = Vector3.new(0, 0, 0)
end

return ShotBobble

local RecoilCamera = {}
RecoilCamera.__index = RecoilCamera

-- Spring-based camera recoil closer to donor ACS behavior
local function createSpring(stiffness, damping)
return {
position = 0,
velocity = 0,
stiffness = stiffness or 85,
damping = damping or 12
}
end

local function updateSpring(spring, dt)
local accel = -spring.stiffness * spring.position - spring.damping * spring.velocity
spring.velocity = spring.velocity + accel * dt
spring.position = spring.position + spring.velocity * dt

if math.abs(spring.position) < 0.0001 and math.abs(spring.velocity) < 0.001 then
	spring.position = 0
	spring.velocity = 0
end

return spring.position


end

function RecoilCamera.new()
local self = setmetatable({}, RecoilCamera)

-- Separate springs for pitch, yaw, roll - donor uses independent axes
self.pitchSpring = createSpring(92, 14)
self.yawSpring = createSpring(78, 11)
self.rollSpring = createSpring(65, 9)

-- Accumulated impulses for rapid fire
self.pitchAccum = 0
self.yawAccum = 0
self.rollAccum = 0

return self


end

function RecoilCamera:Recoil(x, y, z)
-- x = pitch impulse, y = yaw impulse, z = roll impulse
-- Add to velocity for instant response, donor-like feel
self.pitchSpring.velocity = self.pitchSpring.velocity + x
self.yawSpring.velocity = self.yawSpring.velocity + y
self.rollSpring.velocity = self.rollSpring.velocity + z
end

function RecoilCamera:Update(dt)
dt = math.min(dt, 0.033)

local pitch = updateSpring(self.pitchSpring, dt)
local yaw = updateSpring(self.yawSpring, dt)
local roll = updateSpring(self.rollSpring, dt)

-- Return CFrame for camera rotation
return CFrame.Angles(pitch, yaw, roll)


end

function RecoilCamera:Reset()
self.pitchSpring.position = 0
self.pitchSpring.velocity = 0
self.yawSpring.position = 0
self.yawSpring.velocity = 0
self.rollSpring.position = 0
self.rollSpring.velocity = 0
end

return RecoilCamera

