function RecoilSystem:Reset()
self.pitch = 0
self.yaw = 0
self.roll = 0
self.pitchVel = 0
self.yawVel = 0
self.rollVel = 0
self.posX = 0
self.posY = 0
self.posZ = 0
self.velX = 0
self.velY = 0
self.velZ = 0
self.shotsFired = 0
self.sprayAmount = 0
self.patternIndex = 0
end

-- Получить текущий spray amount
function RecoilSystem:GetSprayAmount()
return self.sprayAmount
end

-- Получить количество выстрелов
function RecoilSystem:GetShotsFired()
return self.shotsFired
end

return RecoilSystem

