	local posY = pos.Y * 0.30
	local posZ = pos.Z * 0.34

	local rotX = rot.X
	local rotY = rot.Y
	local rotZ = rot.Z

	if abs(posX) < 0.00002 then posX = 0 end
	if abs(posY) < 0.00002 then posY = 0 end
	if abs(posZ) < 0.00002 then posZ = 0 end

	if abs(rotX) < 0.00002 then rotX = 0 end
	if abs(rotY) < 0.00002 then rotY = 0 end
	if abs(rotZ) < 0.00002 then rotZ = 0 end

	local posCF = CFrame.new(posX, posY, posZ)
	local rotCF = CFrame.Angles(rotX, rotY, rotZ)

