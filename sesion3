local random = math.random
local sin = math.sin
local cos = math.cos
local pi = math.pi
local min = math.min

function ShotBobble.new()
local self = setmetatable({}, ShotBobble)

self.intensity = 0
self.phase = random() * pi * 2

-- мягче и короче
self.decayRate = 10.0
self.frequency = 10.5

self.currentPos = Vector3.new(0, 0, 0)
self.currentRot = Vector3.new(0, 0, 0)

return self


end

function ShotBobble:Trigger(amount)
amount = amount or 1

-- не даём бесконечно копиться
self.intensity = min(self.intensity + amount * 0.45, 0.55)

-- лёгкий сдвиг, а не полная смена фазы
self.phase = self.phase + (random() - 0.5) * 0.45


end

