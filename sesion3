	self.posSpring = createSpring(165, 24)
	self.rotSpring = createSpring(145, 22)

	self.sideBias = -0.16

	return self
end

function ShotViewKick:FireKick(x, y, z)
	x = x or 0
	y = y or 0
	z = z or 0

	local lateral = x + self.sideBias * (0.65 + random() * 0.35)
	local vertical = y
	local depth = z

	self.posSpring.velocity = self.posSpring.velocity + Vector3.new(
		lateral * 1.15,
		vertical * 1.45,
		depth * 1.65
	)

	self.rotSpring.velocity = self.rotSpring.velocity + Vector3.new(
		(-vertical * 0.78) + rad(random(-3, 2) * 0.01),
		(lateral * 0.34),
		(lateral * 0.18) + (depth * 0.08)
	)
end

