	if not profile then return end

	adsSwayScale = profile.adsSwayScale or VM_Config.adsMotionScale

	local isHip = not aimming

	local runtimeProfile = profile
	if isHip then
		runtimeProfile = table.clone(profile)

		runtimeProfile.kickStrength = (profile.kickStrength or 0.0104) * 0.34
		runtimeProfile.horizontalStrength = (profile.horizontalStrength or 0.0072) * 0.85
		runtimeProfile.horizontalRandomness = math.max(profile.horizontalRandomness or 0.06, 0.30)

		runtimeProfile.patternScale = (profile.patternScale or 0.0245) * 0.42
		runtimeProfile.gunKickback = (profile.gunKickback or 0.0145) * 0.42
		runtimeProfile.gunRise = (profile.gunRise or 0.0068) * 0.36

		runtimeProfile.verticalMult = (profile.verticalMult or 0.94) * 0.72
		runtimeProfile.horizontalMult = 1.0
		runtimeProfile.leftBias = 0

		runtimeProfile.springStiffness = profile.hipReturnStiffness or 92.0
		runtimeProfile.springDamping = profile.hipReturnDamping or 28.0
		runtimeProfile.returnSpeed = profile.hipReturnSpeed or 0.26
		runtimeProfile.returnSmoothness = profile.hipReturnSmoothness or 0.88

		if profile.pattern then
			runtimeProfile.pattern = {}
			for i, point in ipairs(profile.pattern) do
				runtimeProfile.pattern[i] = {
					x = point.x * 1.25,
					y = point.y * 0.45,
				}
			end
		end
	end

	if gunRecoilState.currentProfile ~= runtimeProfile then
		gunRecoilState:SetProfile(runtimeProfile)
	end

	local baseMult = 1.0
	if aimming then
		baseMult = baseMult * (profile.aimMultiplier or 0.3)
	end
	if Crouched then
		baseMult = baseMult * (profile.crouchMultiplier or 0.65)
	end
	if BipodActive then
		baseMult = baseMult * 0.3
	end
	if charspeed > 0.1 then
		baseMult = baseMult * (profile.moveMultiplier or 1.2)
	end
	baseMult = baseMult * (RecoilPower or 1) * 2.35

	local recoilMult = baseMult
	local donorMult = baseMult

	if isHip then
		recoilMult = recoilMult * (profile.hipRecoilScale or 0.62)
		donorMult = donorMult * (profile.hipDonorRecoilScale or 0.95)
	else
		recoilMult = recoilMult * (profile.adsRecoilCFScale or 0.58)
		donorMult = donorMult * (profile.adsDonorRecoilScale or 0.58)
	end

	gunRecoilState:Kick(runtimeProfile, recoilMult)

	donorRecoilState:SetProfile(runtimeProfile)
	donorRecoilState:Kick(runtimeProfile, WeaponInHand, donorMult)

	local camX, camY = donorRecoilState:GetCameraRecoil()
	if isHip then
		recoilCameraState:Recoil(
			camX * (profile.hipCameraX or 0.32),
			camY * (profile.hipCameraY or 0.28),
			0
		)
		shotViewKickState:FireKick(0, profile.hipShotKickY or -0.030, profile.hipShotKickZ or 0.022)
		shotBobbleState:Trigger(profile.hipBobbleAmount or 0.38)
	else
		recoilCameraState:Recoil(camX * 0.8, camY * 0.6, 0)
		shotViewKickState:FireKick(0, -0.08, 0.05)
		shotBobbleState:Trigger(1)
	end

	local camRecoil = gunRecoilState:GetCameraRecoil()
	local camPower = isHip and (profile.hipCamRecoilPower or 0.08) or (profile.adsCamRecoilPower or 0.22)
	cameraspring:accelerate(Vector3.new(
		math.rad(camRecoil.Y) * camPower,
		math.rad(camRecoil.X) * camPower,
		math.rad(camRecoil.X * 0.04) * camPower
	))

	local kick = isHip and 1.0 or 0.55
	if BipodActive then
		kick = kick * 0.4
	end

	local hipMult = isHip and (WeaponData.HipRecoilMult or 1.15) or 1
	local adsMult = aimming and (WeaponData.ADSRecoilMult or 0.85) or 1
	kick = kick * hipMult * adsMult

	local viewKickScale
	local hitScale
	local vertScale
	local yawMin, yawMax
	local rollMin, rollMax
	local secXMin, secXMax
	local secYMin, secYMax

	if isHip then
		kick = kick * (profile.hipVMKickScale or 0.18)
		viewKickScale = profile.hipViewKickScale or 0.42
		hitScale = 0.16
		vertScale = 0.72

		yawMin, yawMax = -1.35, 1.35
		rollMin, rollMax = -0.95, 0.95

		secXMin, secXMax = -1.15, 1.15
		secYMin, secYMax = -0.75, 0.75
	else
		viewKickScale = profile.adsViewKickScale or 0.42
		hitScale = 0.24
		vertScale = 0.90

		yawMin, yawMax = -1.2, 1.2
		rollMin, rollMax = -0.8, 1.1

		secXMin, secXMax = -1.2, 1.2
		secYMin, secYMax = -0.8, 0.8
	end

	local kickVM = kick * viewKickScale
	local vm = 0.52

	VMKickPos:accelerate(Vector3.new(
		0,
		0.70 * kickVM * vm * hitScale * vertScale,
		-0.95 * kickVM * vm * hitScale
	))

	VMKickRot:accelerate(Vector3.new(
		math.rad(1.9) * kickVM * vm * hitScale * vertScale,
		math.rad(RAND(yawMin, yawMax, 0.5)) * kickVM * vm * hitScale,
		math.rad(RAND(rollMin, rollMax, 0.5)) * kickVM * vm * hitScale
	))

	SecondarySpring:accelerate(Vector3.new(
		math.rad(RAND(secXMin, secXMax, 0.5)) * kick * vm * hitScale,
		math.rad(RAND(secYMin, secYMax, 0.5)) * kick * vm * hitScale,
		0
	))
end


