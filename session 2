-- damping: damping ratio (default 1, critical damping)
-- mass: mass of the spring (default 1)
-- initialValue: starting position (number or Vector3)
-- targetValue: target position (number or Vector3)
function DonorSpring.new(frequency, damping, mass, initialValue, targetValue)
local self = setmetatable({}, DonorSpring)

-- Spring parameters
self.Frequency = frequency or 1
self.Damping = damping or 1
self.Mass = mass or 1

-- Snap distance threshold
self.SnapDistance = DEFAULT_SNAP_DISTANCE

-- State
local isVec = isVector3(initialValue)
local zero = getZero(initialValue or (isVec and Vector3.new(0,0,0) or 0))

self.Position = initialValue or zero
self.Velocity = zero
self.Target = targetValue or zero

return self


