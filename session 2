dt = clamp(dt, 0.0001, 0.1)

local frequency = self.Frequency
local damping = self.Damping
local mass = self.Mass

-- Calculate spring constants
-- omega = 2 * pi * frequency
-- Using donor-style spring physics
local omega = 2 * pi * frequency
local omega2 = omega * omega

-- Damping coefficient
-- For critical damping: damping = 1
-- For underdamped: damping < 1
-- For overdamped: damping > 1
local zeta = damping

-- Calculate displacement from target
local displacement = subtract(self.Position, self.Target)

-- Spring force: -k * x where k = omega^2 * mass
-- Damping force: -c * v where c = 2 * zeta * omega * mass
local springForce = multiply(displacement, -omega2 * mass)
local dampingForce = multiply(self.Velocity, -2 * zeta * omega * mass)

-- Total force
local totalForce = add(springForce, dampingForce)

-- Acceleration = Force / Mass
local acceleration = multiply(totalForce, 1 / mass)

-- Semi-implicit Euler integration (more stable)
self.Velocity = add(self.Velocity, multiply(acceleration, dt))
self.Position = add(self.Position, multiply(self.Velocity, dt))

